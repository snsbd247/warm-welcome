APP_NAME="Smart ISP"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com/api
APP_TIMEZONE=Asia/Dhaka
APP_VERSION=1.0.2

FRONTEND_URL=https://yourdomain.com

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=isp_management
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@smartisp.com"
MAIL_FROM_NAME="Smart ISP"

# GreenWeb SMS
GREENWEB_SMS_TOKEN=

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=

# bKash Tokenized Payment (use v1.2.0 for production)
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.pay.bka.sh/v1.2.0

# bKash Pay Bill (Merchant)
BKASH_PAYBILL_APP_KEY=
BKASH_PAYBILL_APP_SECRET=
BKASH_PAYBILL_USERNAME=
BKASH_PAYBILL_PASSWORD=
BKASH_PAYBILL_BASE_URL=https://tokenized.pay.bka.sh/v1.2.0

# Nagad Payment
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=
NAGAD_PUBLIC_KEY=
NAGAD_PRIVATE_KEY=
NAGAD_BASE_URL=https://api.mynagad.com/api/dfs

# Sanctum (add your domain)
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,www.yourdomain.com

# Multi-Tenant SaaS
CENTRAL_DOMAINS=smartispapp.com,www.smartispapp.com
SERVER_IP=

# Log Channel (single for cPanel, stack for development)
LOG_CHANNEL=single
LOG_LEVEL=error
