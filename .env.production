# Production environment for cPanel deployment
# ─── Option 1: Same domain (public_html/api/) ───
# VITE_API_URL="https://yourdomain.com/api/api"
#
# ─── Option 2: Subdomain (api.yourdomain.com) ───
# VITE_API_URL="https://api.yourdomain.com/api"
#
# 👇 আপনার domain দিয়ে নিচেরটা আপডেট করুন:
VITE_API_URL="https://yourdomain.com/api/api"
