# Production environment — cPanel deployment
# Set VITE_API_URL to use Laravel/MySQL backend instead of Supabase
# Example: VITE_API_URL="https://your-domain.com/api/api"
# 
# When this is set, ALL data operations go through Laravel API.
# When NOT set (Lovable preview), data goes directly to Supabase.
#
# Uncomment and set your domain:
# VITE_API_URL="https://smartisp.ismail.bd/api/api"
